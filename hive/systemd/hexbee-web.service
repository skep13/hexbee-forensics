[Unit]
Description=HexBee Hive web dashboard and REST API
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=hexbee
Group=hexbee
EnvironmentFile=-/etc/hexbee/hive.env
ExecStart=/opt/hexbee/venv/bin/hexbee-hive web
Restart=always
RestartSec=5
MemoryMax=250M
NoNewPrivileges=true
ProtectSystem=strict
ReadWritePaths=/var/lib/hexbee

[Install]
WantedBy=multi-user.target
